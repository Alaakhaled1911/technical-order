<odoo>
        <record id="reject_reason_view_form" model="ir.ui.view">
        <field name="name">reject.reason.form</field>
        <field name="model">reject.wizard</field>
        <field name="arch" type="xml">
            <form>
               <group>
                   <field name="order_id" invisible="1" />
                   <field name="rejection_reason"/>
               </group>
                    <footer>
                        <button string="Cancel" special="cancel" name="action_cancel" class="btn-secondary" />
                        <button string="Confirm" type="object" name="action_confirm" class="btn-primary" />
                    </footer>

            </form>
        </field>
    </record>


</odoo>