<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    <record id="action_technical_order_report" model="ir.actions.report">
        <field name="name">Technical Order Report</field>
        <field name="model">technical.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">technical_order.report_technical_order</field>
        <field name="report_file">technical_order.report_technical_order</field>
        <field name="binding_model_id" ref="model_technical_order"/>
        <field name="binding_type">report</field>
    </record>

   
    <template id="report_technical_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">

                    <div class="page">

                        <div class="text-center mb-4">
                            <h2 style="font-weight: bold;">Technical Order</h2>
                            <h4 style="color: #555;">
                                <t t-esc="doc.ref"/>
                            </h4>
                        </div>



                      <table style="width:100%; border-collapse:collapse; margin-top:16px;">

                          <thead>
                                <tr style="background:#4a4a4a; color:white;">
                                    <th style="width:30%; padding:10px; border:1px solid #ccc;">Field</th>
                                    <th style="padding:10px; border:1px solid #ccc;">Value</th>
                                </tr>
                            </thead>
                          <tbody>
                                <tr>
                                    <th style="padding:10px; border:1px solid #ccc; background:#f5f5f5;">Requested By</th>
                                    <td style="padding:10px; border:1px solid #ccc;">
                                        <t t-esc="doc.requested_by.name or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="padding:10px; border:1px solid #ccc; background:#f5f5f5;">Customer</th>
                                    <td style="padding:10px; border:1px solid #ccc;">
                                        <t t-esc="doc.customer.name or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="padding:10px; border:1px solid #ccc; background:#f5f5f5;">Start Date</th>
                                    <td style="padding:10px; border:1px solid #ccc;">
                                        <t t-esc="doc.start_date or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="padding:10px; border:1px solid #ccc; background:#f5f5f5;">End Date</th>
                                    <td style="padding:10px; border:1px solid #ccc;">
                                        <t t-esc="doc.end_date or '-'"/>
                                    </td>
                                </tr>
                            </tbody>
                      </table>


                        <div class="row mt-4 mb-4" style="margin-top:20px !important; margin-bottom:20px !important">

                            <div class="col-6">
                                <strong>Status:</strong>
                                <span style="color:#c0392b; font-weight:bold;">
                                    <t t-esc="dict(doc._fields['state'].selection).get(doc.state)"/>
                                </span>
                            </div>

                            <t t-if="doc.rejection_reason">
                                <div class="col-6">
                                    <div class="p-3" style="background:#fdecea; border-radius:4px;">
                                        <strong>Rejection Reason:</strong><br/>
                                        <t t-esc="doc.rejection_reason"/>
                                    </div>
                                </div>
                            </t>

                        </div>


                        <table class="table mt-4" style="width:100%; border-collapse:collapse;">
                            <thead style="background:#f5f5f5;">
                                <tr>
                                    <th style="padding:10px; border:1px solid #ddd;">Product</th>
                                    <th style="padding:10px; border:1px solid #ddd;">Description</th>
                                    <th style="padding:10px; border:1px solid #ddd; text-align:center;">Qty</th>
                                    <th style="padding:10px; border:1px solid #ddd; text-align:right;">Price</th>
                                    <th style="padding:10px; border:1px solid #ddd; text-align:right;">Total</th>
                                </tr>
                            </thead>

                            <tbody>
                                <t t-foreach="doc.order_line_ids" t-as="line">
                                    <tr>
                                        <td style="padding:8px; border:1px solid #ddd;">
                                            <t t-esc="line.product_id.name"/>
                                        </td>

                                        <td style="padding:8px; border:1px solid #ddd;">
                                            <t t-esc="line.description"/>
                                        </td>

                                        <td style="padding:8px; border:1px solid #ddd; text-align:center;">
                                            <t t-esc="line.quantity"/>
                                        </td>

                                        <td style="padding:8px; border:1px solid #ddd; text-align:right;">
                                            <t t-esc="line.price"/>
                                        </td>

                                        <td style="padding:8px; border:1px solid #ddd; text-align:right;">
                                            <t t-esc="line.total"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>

                            <tfoot>
                                <tr>
                                    <td colspan="4" style="padding:10px; text-align:center; border:1px solid #ddd;">
                                        <strong>Total Price</strong>
                                    </td>
                                    <td style="padding:10px; text-align:right; border:1px solid #ddd; font-weight:bold;">
                                        <t t-esc="doc.total_price"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>
